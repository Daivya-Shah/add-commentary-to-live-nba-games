# Copy to `backend/.env` for local use. Never put real API keys in this file (it may be committed).

OPENAI_API_KEY=

# Optional overrides
OPENAI_VISION_MODEL=gpt-4o-mini
# low | high | auto — high helps read jersey numbers (more tokens)
OPENAI_VISION_IMAGE_DETAIL=high
# Match jersey # to NBA rosters via stats.nba.com (nba_api). Set 0 to disable.
NBA_ROSTER_LOOKUP=1
# Min fuzzy score (0–100) to treat a string as a team hint; avoids bare "Los Angeles" locking wrong LA team.
NBA_TEAM_HINT_MIN_SCORE=35
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx
FRAME_SAMPLE_COUNT=16
# Max frames per chunk window (spacing still ≤ ~2s; raises cap for long chunks)
FRAME_SAMPLE_MAX=32

# Long-video chunking: smaller windows + overlap + continuity reduce errors at cuts.
# If CHUNK_AUTO_SHRINK=1 and video > 75s, chunk length is capped at CHUNK_SIZE_MAX_SEC (default 18).
CHUNK_THRESHOLD_SEC=20
CHUNK_SIZE_SEC=15
CHUNK_SIZE_MAX_SEC=18
CHUNK_AUTO_SHRINK=1
# Re-sample ~CHUNK_OVERLAP_SEC at each boundary; overlap segments from the prior chunk are dropped to avoid duplicates.
CHUNK_OVERLAP_SEC=2

# OpenAI rate limits: cap parallel requests + bounded completion sizes (lowers TPM spikes)
OPENAI_MAX_CONCURRENT_REQUESTS=2
OPENAI_VISION_MAX_OUTPUT_TOKENS=2048
OPENAI_COMMENTARY_MAX_TOKENS=300
OPENAI_FRAME_MAX_OUTPUT_TOKENS=100
OPENAI_TIMELINE_COMMENTARY_MAX_TOKENS=640
OPENAI_SEGMENT_LINE_MAX_TOKENS=48
OPENAI_VISUAL_SUMMARY_MAX_TOKENS=240

# OpenAI 429 / transient errors: exponential backoff + retries (does not raise org TPM cap)
OPENAI_RETRY_MAX_ATTEMPTS=8
OPENAI_RETRY_BASE_SEC=0.75
OPENAI_RETRY_MAX_WAIT_SEC=90

# Voiceover: fit TTS to (video_seconds × this), then speed audio by this factor so it matches video length (1.5 → 10.5s slot for 7s clip, played 1.5× → 7s). Range 1.0–2.0.
VOICEOVER_PLAYBACK_SPEED=1.5

# Fast /regenerate without re-running vision: same Supabase project as the app
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated origins if you call FastAPI from the browser during dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
