# Copy to `backend/.env` for local use. Never put real API keys in this file (it may be committed).

OPENAI_API_KEY=

# Optional overrides
OPENAI_VISION_MODEL=gpt-4o-mini
# low | high | auto — high helps read jersey numbers (more tokens)
OPENAI_VISION_IMAGE_DETAIL=high
# Match jersey # to NBA rosters via stats.nba.com (nba_api). Set 0 to disable.
NBA_ROSTER_LOOKUP=1
# Min fuzzy score (0–100) to treat a string as a team hint; avoids bare "Los Angeles" locking wrong LA team.
NBA_TEAM_HINT_MIN_SCORE=35
OPENAI_TEXT_MODEL=gpt-4o-mini
# Live caption enrichment text model; optimized separately for latency.
OPENAI_LIVE_TEXT_MODEL=gpt-5.4-nano
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx
FRAME_SAMPLE_COUNT=16
# Live Replay: set 0 to keep the hot path feed/template-driven and skip live vision calls.
LIVE_VISION_ENABLED=1

# OpenAI 429 / transient errors: retry with backoff (does not raise your TPM cap; reduces failures)
OPENAI_RETRY_MAX_ATTEMPTS=6
OPENAI_RETRY_BASE_SEC=0.5
OPENAI_RETRY_MAX_WAIT_SEC=60

# Voiceover: fit TTS to (video_seconds × this), then speed audio by this factor so it matches video length (1.5 → 10.5s slot for 7s clip, played 1.5× → 7s). Range 1.0–2.0.
VOICEOVER_PLAYBACK_SPEED=1.5

# Fast /regenerate without re-running vision: same Supabase project as the app
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated origins if you call FastAPI from the browser during dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
